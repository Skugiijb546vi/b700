<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:gravity="center_vertical" android:orientation="horizontal" android:background="@drawable/bg_reseller_item" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:paddingStart="14dp" android:paddingEnd="14dp">
    <FrameLayout android:layout_width="36dp" android:layout_height="36dp">
        <View android:background="@drawable/bg_reseller_avatar" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <TextView android:textSize="15sp" android:textStyle="bold" android:textColor="#b388ff" android:gravity="center" android:id="@+id/reseller_initial" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ImageView android:id="@+id/reseller_avatar" android:background="@drawable/bg_reseller_avatar" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:contentDescription="@null"/>
    </FrameLayout>
    <TextView android:textSize="14sp" android:textColor="@color/white" android:id="@+id/reseller_username" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp"/>
    <ImageView android:id="@+id/reseller_copy" android:visibility="gone" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_content_paste" android:tint="@color/icon_tint" android:contentDescription="@null"/>
</LinearLayout>
