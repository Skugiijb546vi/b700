<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:background="@drawable/bg_gradient_dark" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:overScrollMode="never">
    <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:padding="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="26sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/resellers_title"/>
        <TextView android:textSize="14sp" android:textColor="@color/text_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:layout_marginBottom="32dp" android:text="@string/resellers_subtitle"/>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:baselineAligned="false">
            <androidx.cardview.widget.CardView android:id="@+id/card_telegram" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardBackgroundColor="@android:color/transparent" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:background="@drawable/bg_reseller_card" android:paddingTop="15dp" android:paddingBottom="15dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="5dp" android:paddingEnd="5dp">
                    <FrameLayout android:layout_width="50dp" android:layout_height="50dp">
                        <View android:background="@drawable/bg_icon_circle_accent" android:layout_width="match_parent" android:layout_height="match_parent"/>
                        <ImageView android:layout_gravity="center" android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/ic_telegram_social" android:tint="#b388ff" android:contentDescription="@string/telegram_channel"/>
                    </FrameLayout>
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/telegram_channel"/>
                    <TextView android:textSize="11sp" android:textColor="@color/text_subtitle" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/telegram_channel_desc"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:id="@+id/card_support" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" app:cardBackgroundColor="@android:color/transparent" app:cardCornerRadius="20dp" app:cardElevation="0dp">
                <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:background="@drawable/bg_reseller_card" android:paddingTop="15dp" android:paddingBottom="15dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="5dp" android:paddingEnd="5dp">
                    <FrameLayout android:layout_width="50dp" android:layout_height="50dp">
                        <View android:background="@drawable/bg_icon_circle_accent" android:layout_width="match_parent" android:layout_height="match_parent"/>
                        <ImageView android:layout_gravity="center" android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/ic_support_agent" android:tint="#b388ff" android:contentDescription="@string/technical_support"/>
                    </FrameLayout>
                    <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/technical_support"/>
                    <TextView android:textSize="11sp" android:textColor="@color/text_subtitle" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/technical_support_desc"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <TextView android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="@string/resellers_list_title"/>
        <TextView android:textSize="13sp" android:textColor="@color/text_hint" android:gravity="center" android:id="@+id/tv_loading" android:visibility="visible" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/loading_resellers"/>
        <TextView android:textSize="13sp" android:textColor="@color/text_hint" android:gravity="center" android:id="@+id/tv_empty" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/no_resellers"/>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_resellers" android:visibility="gone" android:clipToPadding="false" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:overScrollMode="never" android:nestedScrollingEnabled="false"/>
        <TextView android:textSize="12sp" android:textColor="@color/text_hint" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="@string/resellers_warning" android:lineSpacingExtra="4dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
