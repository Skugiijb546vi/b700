<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:background="@drawable/bg_reseller_card" android:padding="24dp" android:layout_width="match_parent" android:layout_height="wrap_content">
    <TextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:layout_gravity="center_horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/contact_reseller_title"/>
    <TextView android:textSize="13sp" android:textColor="@color/text_hint" android:layout_gravity="center_horizontal" android:id="@+id/tv_reseller_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp"/>
    <View android:background="#33ffffff" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:baselineAligned="false">
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/btn_telegram" android:background="@drawable/bg_reseller_item" android:padding="16dp" android:focusable="true" android:clickable="true" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp">
            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_telegram_social" android:tint="#b388ff" android:contentDescription="@null"/>
            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/telegram"/>
        </LinearLayout>
        <LinearLayout android:gravity="center" android:orientation="vertical" android:id="@+id/btn_whatsapp" android:background="@drawable/bg_reseller_item" android:padding="16dp" android:focusable="true" android:clickable="true" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/whatsapp" android:tint="#25d366" android:contentDescription="@null"/>
            <TextView android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/whatsapp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
