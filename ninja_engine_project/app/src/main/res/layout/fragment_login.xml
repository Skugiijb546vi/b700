        <LinearLayout android:gravity="center" android:orientation="horizontal" android:id="@+id/social_links" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/btn_find_reseller">
