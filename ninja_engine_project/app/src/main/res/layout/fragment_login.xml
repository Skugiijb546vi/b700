        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout android:textColorHint="@color/text_hint" android:id="@+id/layout_password" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:importantForAccessibility="noHideDescendants" android:layout_marginStart="32dp" android:layout_marginEnd="32dp" app:boxBackgroundColor="@color/input_bg" app:boxCornerRadiusBottomEnd="12dp" app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusTopEnd="12dp" app:boxCornerRadiusTopStart="12dp" app:boxStrokeColor="@color/input_box_stroke" app:boxStrokeWidth="1dp" app:endIconMode="password_toggle" app:endIconTint="@color/icon_tint" app:hintTextColor="@color/accent_purple" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/layout_username" app:startIconDrawable="@drawable/ic_lock_outline" app:startIconTint="@color/icon_tint" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
